# ┌────────────────────────────────────────┐
# │  DouBase 环境配置文件                   │
# │                                        │
# │  复制为 .env 并填入你的实际值           │
# │  cp .env.example .env                  │
# └────────────────────────────────────────┘

# === 核心 Provider 选择 ===
DOUBASE_LLM_PROVIDER=deepseek
DOUBASE_EMBEDDING_PROVIDER=zhipu

# === DeepSeek (LLM) ===
DOUBASE_DEEPSEEK_API_KEY=sk-your-deepseek-key
DOUBASE_DEEPSEEK_MODEL=deepseek-chat
DOUBASE_DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# === OpenAI (LLM) ===
DOUBASE_OPENAI_API_KEY=sk-your-openai-key
DOUBASE_OPENAI_MODEL=gpt-4o
DOUBASE_OPENAI_BASE_URL=https://api.openai.com/v1

# === 自定义兼容 API (LLM)，如 Ollama / vLLM ===
DOUBASE_CUSTOM_API_KEY=
DOUBASE_CUSTOM_MODEL=your-model
DOUBASE_CUSTOM_BASE_URL=https://your-api.com/v1

# === 智谱 (Embedding) ===
DOUBASE_ZHIPU_API_KEY=your-zhipu-key
DOUBASE_ZHIPU_MODEL=embedding-2
DOUBASE_ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# === 本地 Embedding 模型 ===
DOUBASE_LOCAL_MODEL_NAME=BAAI/bge-small-zh-v1.5

# === ChromaDB 存储 (可选，默认值见 config.yaml) ===
# DOUBASE_VECTOR_DIR=~/.doubase/vectors
# DOUBASE_COLLECTION_NAME=notes

# === 监控目录 (可选，默认值见 config.yaml) ===
# DOUBASE_INBOX_DIR=~/Documents/inbox
